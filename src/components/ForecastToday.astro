---
// TODAY ON THE BAY - the live-conditions moment.
// Sits between the mind-shaper and the fleet so the page reads: picture your day,
// see what today actually looks like on the water, then meet the boats. The whole
// point of the feature is that it is LIVE, so this band fetches the real current
// Sarasota conditions in the browser (Open-Meteo NOAA models) and fills the panel.
// Data + derivation come from ../lib/boating-forecast.js, shared with /forecast.
//
// Layout family: asymmetric split (copy left, live readout right). Distinct from
// the bento (mind-shaper), feature rows (fleet), and the 2-col band (the easy part).
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const forecastHref = base + 'forecast';
---

<section class="ft section-y" id="forecast-today" aria-labelledby="ft-h">
  <div class="container-x ft__inner">
    <div class="ft__copy reveal">
      <h2 class="t-h1 ft__title" id="ft-h">Good day to get on the water?</h2>
      <p class="ft__body">
        We keep an eye on the Sarasota forecast so you know before you go. Here is what today
        looks like out on the bay, pulled live the moment you opened the page.
      </p>
      <a class="btn btn-primary ft__cta" href={forecastHref}>See the full forecast</a>
    </div>

    {/* Live readout. Rendered server-side as a skeleton, filled by the script below. */}
    <div class="ft__panel-wrap reveal" style="--reveal-delay: 90ms">
      <div class="ft-panel" data-ft-panel data-state="loading" aria-live="polite">
        <div class="ft-panel__top">
          <span class="ft-panel__where">Today on the water, Sarasota Bay</span>
          <span class="ft-panel__date" data-ft-date>Today</span>
        </div>

        <div class="ft-panel__verdict">
          <span class="ft-badge" data-ft-verdict data-level="loading">Reading the water</span>
        </div>

        <div class="ft-metrics">
          <div class="ft-metric">
            <span class="ft-metric__label">Wind</span>
            <span class="ft-metric__val" data-ft-wind-v>00</span>
            <span class="ft-metric__sub" data-ft-wind-s>kt</span>
          </div>
          <div class="ft-metric">
            <span class="ft-metric__label">Seas</span>
            <span class="ft-metric__val" data-ft-seas-v>0</span>
            <span class="ft-metric__sub" data-ft-seas-s>ft</span>
          </div>
          <div class="ft-metric">
            <span class="ft-metric__label">UV index</span>
            <span class="ft-metric__val" data-ft-uv-v>0</span>
            <span class="ft-metric__sub" data-ft-uv-s>of 11</span>
          </div>
        </div>

        <p class="ft-summary" data-ft-summary>Reading the live Sarasota forecast.</p>
        <p class="ft-foot" data-ft-foot></p>
      </div>
    </div>
  </div>
</section>

<script>
  import { fetchWeather, deriveConditions, etToday } from '../lib/boating-forecast.js';

  // Default "rental day" window, 9 AM to 5 PM, the typical day out.
  const WIN_START = 9.0, WIN_END = 17.0;

  const panel = document.querySelector('[data-ft-panel]');
  if (panel) {
    const set = (sel, text) => { const el = panel.querySelector(sel); if (el) el.textContent = text; };
    const date = etToday();

    fetchWeather(date)
      .then((raw) => {
        const errors = raw.errors;
        const f = deriveConditions(date, raw.fc, raw.mar, null, errors, WIN_START, WIN_END);

        set('[data-ft-date]', f.date.dow + ', ' + f.date.mo + ' ' + f.date.num);

        const badge = panel.querySelector('[data-ft-verdict]');
        if (badge) { badge.textContent = f.verdict.stamp; badge.setAttribute('data-level', f.verdict.level); }

        set('[data-ft-wind-v]', f.wind.value);
        set('[data-ft-wind-s]', 'kt ' + f.wind.dir);

        if (f.seas.maxW != null) {
          set('[data-ft-seas-v]', f.seas.value);
          set('[data-ft-seas-s]', 'ft ' + f.seas.periodTag);
        } else {
          // No fabricated seas: drop the metric rather than show a guess.
          const seasMetric = panel.querySelector('[data-ft-seas-v]').closest('.ft-metric');
          if (seasMetric) seasMetric.remove();
        }

        set('[data-ft-uv-v]', f.uv.value);
        set('[data-ft-uv-s]', f.uv.word || 'of 11');

        // Plain-text summary (strip the bold markers used on the full card).
        set('[data-ft-summary]', f.verdict.note.replace(/<[^>]+>/g, ''));
        set('[data-ft-foot]', 'Live, updated ' + f.updated);

        panel.setAttribute('data-state', 'ok');
      })
      .catch(() => {
        // Forecast source unreachable. Stay honest: no numbers, just an invitation.
        panel.setAttribute('data-state', 'error');
        const badge = panel.querySelector('[data-ft-verdict]');
        if (badge) { badge.textContent = 'Forecast'; badge.setAttribute('data-level', 'good'); }
        set('[data-ft-summary]', 'We could not reach the live forecast just now. Open the full forecast to check today on the water.');
        set('[data-ft-foot]', '');
      });
  }
</script>

<style>
  .ft {
    background-color: var(--color-ink);
    color: var(--color-white);
  }
  .ft__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1.5rem + 3vw, 3.5rem);
    align-items: center;
  }
  .ft__title {
    color: var(--color-white);
    max-width: 14ch;
  }
  .ft__body {
    margin-top: 1.25rem;
    font-size: 1.1875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    max-width: 40ch;
  }
  .ft__cta {
    margin-top: 1.75rem;
  }

  /* ---- Live readout panel: the brand's forecast object, condensed ---- */
  .ft-panel {
    background: var(--color-white);
    color: var(--color-ink);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: clamp(1.375rem, 1.1rem + 1.5vw, 2rem);
  }
  .ft-panel__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-slate) 20%, transparent);
  }
  .ft-panel__where {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-slate);
  }
  .ft-panel__date {
    flex: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-white);
    background: radial-gradient(130% 130% at 20% 10%, #0a3a78, #002454);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .ft-panel__verdict {
    margin-top: 1.25rem;
  }
  .ft-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.375rem, 1.2rem + 0.8vw, 1.75rem);
    letter-spacing: -0.01em;
    color: var(--color-ink);
    background: var(--color-sun);
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-pill);
    box-shadow: 0 6px 18px rgba(252, 216, 12, 0.35);
  }
  .ft-badge[data-level='watch'] {
    background: #ffe88a;
  }
  .ft-badge[data-level='caution'] {
    background: var(--color-white);
    border: 2px solid #e8a13c;
    box-shadow: 0 6px 18px rgba(232, 161, 60, 0.22);
  }
  .ft-badge[data-level='loading'] {
    background: color-mix(in srgb, var(--color-slate) 16%, var(--color-white));
    color: var(--color-slate);
    box-shadow: none;
  }

  .ft-metrics {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .ft-metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 1.125rem;
    border-left: 1px solid color-mix(in srgb, var(--color-slate) 18%, transparent);
  }
  .ft-metric:first-child {
    padding-left: 0;
    border-left: none;
  }
  .ft-metric__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-slate);
  }
  .ft-metric__val {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .ft-metric__sub {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-slate);
  }

  .ft-summary {
    margin-top: 1.5rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-ink);
  }
  .ft-foot {
    margin-top: 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-slate);
  }
  .ft-foot:empty {
    display: none;
  }

  /* ---- Loading skeleton (calm, no spinner). Honors reduced motion. ---- */
  .ft-panel[data-state='loading'] .ft-metric__val,
  .ft-panel[data-state='loading'] .ft-metric__sub {
    color: transparent;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-slate) 16%, var(--color-white));
  }
  .ft-panel[data-state='loading'] .ft-metric__sub {
    background: color-mix(in srgb, var(--color-slate) 12%, var(--color-white));
  }
  .ft-panel[data-state='loading'] .ft-summary {
    color: var(--color-slate);
  }
  @media (prefers-reduced-motion: no-preference) {
    .ft-panel[data-state='loading'] .ft-badge,
    .ft-panel[data-state='loading'] .ft-metric__val,
    .ft-panel[data-state='loading'] .ft-metric__sub {
      animation: ft-pulse 1.4s var(--ease-craft) infinite;
    }
  }
  @keyframes ft-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }

  @media (min-width: 900px) {
    .ft__inner {
      grid-template-columns: 0.92fr 1.08fr;
      gap: clamp(3rem, 2rem + 3vw, 5rem);
    }
  }
</style>
