---
import { Image } from 'astro:assets';
// Real owner photo of Carlos and Liza (IMG_0120).
import aboutImage from '../assets/about.jpg';
---

<section class="about section-y" id="about">
  <div class="container-x about__grid">
    <div class="about__media reveal">
      <Image
        src={aboutImage}
        alt="Carlos and Liza, the family behind Boss Life Rentals, on the water in Sarasota."
        widths={[480, 640]}
        sizes="(min-width: 900px) 480px, 100vw"
        loading="lazy"
        decoding="async"
        class="about__img"
      />
    </div>

    <div class="about__body reveal" style="--reveal-delay: 90ms">
      <h2 class="t-h1 about__title">A Sarasota family who just loves being out here.</h2>
      <p class="about__text">
        We are Carlos and Liza, and our kids, Brianna and Carlitos. We got our boats, our RVs, and
        our jet skis to get outside and enjoy Sarasota as a family, on the water and the open road.
        We had so much fun that we wanted to share it, and we do it together. We keep everything
        clean, fueled, and ready, we meet
        you in person, and we rent it out to folks who want a day like the ones we love. We just want
        you to leave feeling the same way we do out there.
      </p>
      <p class="about__signature"><span class="about__sig-mark">Carlos &amp; Liza</span>, Boss Life Rentals</p>
      <div class="about__actions">
        <a href="#contact" class="btn btn-secondary">Talk to us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--color-surface);
  }
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1.5rem + 3vw, 4rem);
    align-items: center;
  }
  .about__media {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 4 / 3;
  }
  .about__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about__title {
    max-width: 18ch;
  }
  .about__text {
    margin-top: 1.5rem;
    font-size: 1.1875rem;
    max-width: 48ch;
  }
  .about__signature {
    margin-top: 1.75rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-ink);
  }
  .about__sig-mark {
    position: relative;
    white-space: nowrap;
  }
  .about__sig-mark::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.12em;
    height: 0.2em;
    background: var(--color-sun);
    border-radius: 2px;
    opacity: 0.9;
  }
  .about__actions {
    margin-top: 1.75rem;
  }
  @media (min-width: 900px) {
    .about__grid {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }
</style>
