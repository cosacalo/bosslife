---
import { Image } from 'astro:assets';
import { unitsByCategory, categories } from '../data/units.js';
import UnitCard from './UnitCard.astro';
import VenueButtons from './VenueButtons.astro';

// The fleet, equal billing across all three categories, sold by the day each
// gives you. Three distinct layout families keep it from reading as one card
// grid:
//   Boats   - two tall photo feature cards (the real photography).
//   RVs     - two horizontal compact cards.
//   Jet skis - one bold azure color-block panel: intro plus a picture of each
//              Sea-Doo (yellow 170, orange 130), both linking to the shared page.
const boats = unitsByCategory('boat');
const rvs = unitsByCategory('rv');
const jetskis = unitsByCategory('jetski');

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const detailHref = (id) => `${base}fleet/${id}`;

const catBlurb = (key) => categories.find((c) => c.key === key)?.blurb ?? '';

// Jet skis share one page; the panel shows a picture of each ski (yellow 170,
// orange 130). Resolve each model image the same way the gallery does.
const jetski = jetskis[0];
const jsImgModules = import.meta.glob('../assets/units/*/*.{jpg,png}', { eager: true });
const jsImgMap = {};
for (const [path, mod] of Object.entries(jsImgModules)) {
  const m = path.match(/units\/([^/]+)\/([^/]+)$/);
  if (m) jsImgMap[`${m[1]}/${m[2]}`] = mod.default;
}
const jetskiModels = (jetski?.models ?? []).map((mdl) => ({
  ...mdl,
  img: jsImgMap[`${jetski.id}/${mdl.image}`] ?? null,
}));
const jetskiVenues = jetski?.venues ?? [{ name: 'Direct', url: '#contact' }];
---

<section class="fleet section-y" id="fleet">
  <div class="container-x">
    <header class="fleet__head reveal">
      <h2 class="t-h1 fleet__title">Pick your day.</h2>
      <p class="fleet__lead">
        Boats, RVs, and jet skis, all ours, all kept ready. Pick the one that fits the day you want,
        and book where you are most comfortable. Staying a while? We do long-term rentals on any of
        them. Just ask.
      </p>
    </header>

    <!-- Boats: tall photo feature cards -->
    <div class="fleet__group">
      <header class="fleet__group-head reveal">
        <h3 class="t-h2 fleet__group-title">Boats</h3>
        <p class="fleet__group-blurb">{catBlurb('boat')}</p>
      </header>
      <div class="fleet__feature-grid">
        {boats.map((unit) => <UnitCard unit={unit} variant="feature" />)}
      </div>
    </div>

    <!-- RVs: horizontal compact cards -->
    <div class="fleet__group">
      <header class="fleet__group-head reveal">
        <h3 class="t-h2 fleet__group-title">RVs</h3>
        <p class="fleet__group-blurb">{catBlurb('rv')}</p>
      </header>
      <div class="fleet__compact-grid">
        {rvs.map((unit) => <UnitCard unit={unit} variant="compact" />)}
      </div>
    </div>

    <!-- Jet skis: bold azure color-block panel, a picture of each Sea-Doo -->
    <div class="fleet__group">
      <div class="jetski-panel reveal">
        <div class="jetski-panel__intro">
          <h3 class="t-h2 jetski-panel__title">Jet Skis</h3>
          <p class="jetski-panel__blurb">{catBlurb('jetski')}</p>
          <div class="jetski-panel__venues">
            <VenueButtons venues={jetskiVenues} label="" />
          </div>
        </div>
        <div class="jetski-panel__skis">
          {
            jetskiModels.map((m) => (
              <a href={detailHref(jetski.id)} class="jetski-tile">
                <span class="jetski-tile__media">
                  {m.img && (
                    <Image
                      src={m.img}
                      alt={`Sea-Doo ${m.name}, ${m.color}.`}
                      widths={[320, 480, 640]}
                      sizes="(min-width: 760px) 22vw, 45vw"
                      loading="lazy"
                    />
                  )}
                </span>
                <span class="jetski-tile__foot">
                  <span class="jetski-tile__text">
                    <span class="jetski-tile__name">{m.name}</span>
                    <span class="jetski-tile__meta">
                      {m.color} · {m.topSpeed}
                    </span>
                  </span>
                  <span class="jetski-tile__view" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="none">
                      <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fleet {
    background-color: var(--color-surface);
  }
  .fleet__head {
    max-width: 52rem;
    margin-bottom: clamp(3rem, 2rem + 4vw, 5rem);
  }
  .fleet__lead {
    margin-top: 1.25rem;
    font-size: clamp(1.0625rem, 1rem + 0.4vw, 1.25rem);
    color: var(--color-slate);
    max-width: 52ch;
  }
  .fleet__group + .fleet__group {
    margin-top: clamp(3.5rem, 2.5rem + 4vw, 6rem);
  }
  .fleet__group-head {
    max-width: 52rem;
    margin-bottom: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    padding-bottom: 1.125rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-slate) 22%, transparent);
  }
  .fleet__group-title {
    color: var(--color-ink);
  }
  .fleet__group-blurb {
    margin-top: 0.75rem;
    color: var(--color-slate);
    font-size: 1.0625rem;
    max-width: 54ch;
  }

  .fleet__feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 1rem + 2vw, 2.25rem);
  }
  .fleet__compact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 1rem + 1.5vw, 1.75rem);
  }
  @media (min-width: 860px) {
    .fleet__feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1000px) {
    .fleet__compact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Jet ski color-block panel: confident azure feature, equal weight to the
     photo cards above through scale and the bold fill. */
  .jetski-panel {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    /* Deepened azure so the small white blurb clears WCAG AA 4.5:1 across the
       whole panel (raw brand azure + white is only ~4.37). */
    background: radial-gradient(120% 140% at 100% 0%, #1570d4 0%, #0a5fbe 55%, #074a94 100%);
    color: var(--color-white);
    box-shadow: var(--shadow-md);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    padding: clamp(1.75rem, 1.4rem + 2vw, 3rem);
  }
  .jetski-panel__title {
    color: var(--color-white);
  }
  .jetski-panel__blurb {
    margin-top: 0.75rem;
    color: var(--color-white);
    font-size: 1.0625rem;
    max-width: 36ch;
  }
  .jetski-panel__venues {
    margin-top: 1.5rem;
  }
  /* Two white picture tiles (yellow 170, orange 130). The studio profiles sit on
     white, so white tiles read clean and catalog-crisp against the azure ground. */
  .jetski-panel__skis {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.875rem, 0.6rem + 1vw, 1.25rem);
    align-content: start;
  }
  /* Two-up once there is room; stacked full-width tiles on small phones so the
     pictures stay large and the labels never crowd. */
  @media (min-width: 560px) {
    .jetski-panel__skis {
      grid-template-columns: 1fr 1fr;
    }
  }
  .jetski-tile {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s var(--ease-craft), box-shadow 0.25s var(--ease-craft);
  }
  .jetski-tile:hover,
  .jetski-tile:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .jetski-tile__media {
    display: block;
    aspect-ratio: 4 / 3;
    background: var(--color-white);
  }
  .jetski-tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .jetski-tile__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
  }
  .jetski-tile__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  .jetski-tile__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--color-ink);
  }
  .jetski-tile__meta {
    font-size: 0.8125rem;
    color: var(--color-slate);
  }
  .jetski-tile__view {
    flex: none;
    display: inline-flex;
    color: var(--color-azure-ink);
  }
  .jetski-tile__view svg {
    width: 0.9rem;
    height: 0.9rem;
  }
  @media (min-width: 760px) {
    .jetski-panel {
      grid-template-columns: 0.82fr 1.18fr;
      align-items: center;
      gap: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .jetski-tile:hover {
      transform: none;
    }
  }
</style>
