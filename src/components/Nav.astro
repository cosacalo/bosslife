---
// Sticky top nav. Transparent over the hero, gains a surface plate on scroll.
// Anchor links resolve against the site root so the nav also works on detail
// pages (where "#fleet" alone would just stay on the detail page).
//
// IA note: most items are in-page anchor jumps (single-page marketing site).
// "Fleet" is a dropdown of the actual units that link straight to their detail
// pages, so a decided visitor skips the scroll-then-click. Links that navigate to
// a real PAGE (the units, Forecast) carry a small arrow to distinguish them from
// the in-page jumps.
import { units } from '../data/units.js';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const logo = base + 'logo.png';

// On detail pages, anchor links must point back to the home page section.
const { onDetail = false } = Astro.props;
const root = onDetail ? base : '';

const fleetHref = `${root}#fleet`;
const forecastHref = `${base}forecast`;
const homeHref = onDetail ? base : '#top';
const bookHref = `${root}#contact`;

// The fleet units, in display order, each linking straight to its detail page.
const fleetUnits = units.map((u) => ({ name: u.name, href: `${base}fleet/${u.id}` }));
---

<header class="nav" data-nav>
  <div class="container-x nav__inner">
    <a href={homeHref} class="nav__brand" aria-label="Boss Life Rentals, home">
      <img src={logo} alt="Boss Life Rentals" width="160" height="85" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href={`${root}#about`}>Our story</a>

      <div class="nav__drop">
        <a href={fleetHref} class="nav__drop-trigger" aria-haspopup="true">
          Fleet
          <svg class="nav__caret" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <div class="nav__menu" role="menu" aria-label="Fleet">
          {
            fleetUnits.map((u) => (
              <a href={u.href} role="menuitem" class="nav__menu-link" aria-label={u.name}>
                <span>{u.name}</span>
                <svg class="nav__arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3.5 8H12.5M12.5 8 8.5 4M12.5 8 8.5 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <a href={`${root}#why`}>How it works</a>

      <a href={forecastHref} class="nav__pagelink">
        Forecast
        <svg class="nav__arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3.5 8H12.5M12.5 8 8.5 4M12.5 8 8.5 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>

      <a href={`${root}#contact`}>Contact</a>
      <a href={bookHref} class="nav__cta">Book direct</a>
    </nav>

    <button
      class="nav__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
      data-nav-toggle
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu" hidden data-nav-menu>
    <nav class="container-x" aria-label="Mobile">
      <a href={`${root}#about`} data-nav-close>Our story</a>
      <a href={fleetHref} data-nav-close>Fleet</a>
      <div class="nav__mobile-sub">
        {fleetUnits.map((u) => <a href={u.href} data-nav-close class="nav__mobile-subitem">{u.name}</a>)}
      </div>
      <a href={`${root}#why`} data-nav-close>How it works</a>
      <a href={forecastHref} data-nav-close>Forecast</a>
      <a href={`${root}#contact`} data-nav-close>Contact</a>
      <a href={bookHref} data-nav-close class="nav__mobile-cta">Book direct</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var nav = document.querySelector('[data-nav]');
    var toggle = document.querySelector('[data-nav-toggle]');
    var menu = document.querySelector('[data-nav-menu]');
    if (toggle && menu) {
      var setOpen = function (open) {
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        nav.classList.toggle('is-open', open);
        if (open) {
          menu.hidden = false;
        } else {
          menu.hidden = true;
        }
      };
      toggle.addEventListener('click', function () {
        setOpen(toggle.getAttribute('aria-expanded') !== 'true');
      });
      menu.querySelectorAll('[data-nav-close]').forEach(function (a) {
        a.addEventListener('click', function () {
          setOpen(false);
        });
      });
    }
    // Plate on scroll
    if (nav) {
      var onScroll = function () {
        nav.classList.toggle('is-scrolled', window.scrollY > 24);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      background-color 0.3s var(--ease-craft),
      box-shadow 0.3s var(--ease-craft),
      padding 0.7s var(--ease-craft),
      backdrop-filter 0.3s var(--ease-craft);
  }
  .nav.is-scrolled {
    background-color: color-mix(in srgb, var(--color-ink) 92%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow-sm);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.75rem;
    border: 1px solid transparent;
    transition:
      max-width 0.7s var(--ease-craft),
      padding 0.7s var(--ease-craft),
      background-color 0.6s var(--ease-craft),
      border-color 0.6s var(--ease-craft),
      border-radius 0.6s var(--ease-craft),
      box-shadow 0.6s var(--ease-craft);
  }
  .nav__brand img {
    height: 44px;
    width: auto;
  }
  .nav__links {
    display: none;
    gap: 2rem;
    align-items: center;
  }
  .nav__links > a,
  .nav__drop-trigger {
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.9375rem;
    position: relative;
    padding-block: 0.25rem;
  }
  /* Underline sweep on the top-level items only (not dropdown contents). */
  .nav__links > a::after,
  .nav__drop-trigger::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-sun);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-craft);
  }
  .nav__cta::after {
    display: none;
  }
  .nav__links > a:hover::after,
  .nav__links > a:focus-visible::after,
  .nav__drop:hover .nav__drop-trigger::after,
  .nav__drop:focus-within .nav__drop-trigger::after {
    transform: scaleX(1);
  }

  /* Page-link arrow: marks links that go to a real page vs an in-page jump. */
  .nav__pagelink,
  .nav__drop-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .nav__arrow {
    width: 0.8rem;
    height: 0.8rem;
    flex: none;
    opacity: 0.45;
    transition: opacity 0.25s var(--ease-craft), transform 0.25s var(--ease-craft);
  }
  .nav__pagelink:hover .nav__arrow,
  .nav__pagelink:focus-visible .nav__arrow {
    opacity: 0.95;
    transform: translateX(2px);
  }
  .nav__caret {
    width: 0.7rem;
    height: 0.7rem;
    opacity: 0.7;
    transition: transform 0.25s var(--ease-craft);
  }
  .nav__drop:hover .nav__caret,
  .nav__drop:focus-within .nav__caret {
    transform: rotate(180deg);
  }

  /* Fleet dropdown */
  .nav__drop {
    position: relative;
  }
  .nav__menu {
    position: absolute;
    top: 100%;
    left: -0.75rem;
    margin-top: 0.4rem;
    min-width: 13rem;
    background: color-mix(in srgb, var(--color-ink) 95%, #000);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    box-shadow: var(--shadow-lg);
    display: grid;
    gap: 0.0625rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition:
      opacity 0.2s var(--ease-craft),
      transform 0.2s var(--ease-craft),
      visibility 0.2s var(--ease-craft);
    z-index: 60;
  }
  /* Invisible bridge so the menu does not close while crossing the gap. */
  .nav__menu::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: -0.4rem;
    height: 0.4rem;
  }
  .nav__drop:hover .nav__menu,
  .nav__drop:focus-within .nav__menu {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .nav__menu-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    white-space: nowrap;
    padding: 0.55rem 0.7rem;
    border-radius: var(--radius-sm);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background-color 0.2s var(--ease-craft), color 0.2s var(--ease-craft);
  }
  .nav__menu-link:hover,
  .nav__menu-link:focus-visible {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
  }
  .nav__menu-link:hover .nav__arrow,
  .nav__menu-link:focus-visible .nav__arrow {
    opacity: 0.95;
    transform: translateX(2px);
  }

  .nav__cta {
    color: var(--color-ink) !important;
    background: var(--color-sun);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-pill);
    transition: filter 0.2s var(--ease-craft);
  }
  .nav__cta:hover {
    filter: brightness(0.96);
  }
  .nav__mobile-cta {
    color: var(--color-ink) !important;
    background: var(--color-sun);
    border-radius: var(--radius-md);
    text-align: center;
    margin-top: 0.75rem;
    border-bottom: none !important;
  }

  .nav__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-white);
    border-radius: 2px;
    transition: transform 0.25s var(--ease-craft), opacity 0.25s var(--ease-craft);
  }
  .nav.is-open .nav__toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav.is-open .nav__toggle span:nth-child(2) {
    opacity: 0;
  }
  .nav.is-open .nav__toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav__mobile {
    background-color: color-mix(in srgb, var(--color-ink) 97%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .nav__mobile nav {
    display: flex;
    flex-direction: column;
    padding-block: 0.5rem 1rem;
  }
  .nav__mobile a {
    color: var(--color-white);
    font-weight: 600;
    font-size: 1.125rem;
    padding-block: 0.875rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  /* Units nested under Fleet on mobile. */
  .nav__mobile-sub {
    display: flex;
    flex-direction: column;
    border-left: 2px solid rgba(255, 255, 255, 0.14);
    margin-left: 0.25rem;
  }
  .nav__mobile-subitem {
    font-size: 1rem !important;
    font-weight: 500 !important;
    padding-block: 0.6rem !important;
    padding-left: 1rem !important;
    color: rgba(255, 255, 255, 0.82) !important;
    border-bottom: none !important;
  }

  @media (min-width: 768px) {
    .nav__links {
      display: flex;
    }
    .nav__toggle,
    .nav__mobile {
      display: none;
    }

    /* Floating pill on scroll: the full-width bar collapses into a centered,
       blurred, rounded pill, and expands back at the top. The pill carries the
       surface, so the full-width plate is dropped on desktop. */
    .nav.is-scrolled {
      background-color: transparent;
      box-shadow: none;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      padding-top: 0.4rem;
    }
    .nav.is-scrolled .nav__inner {
      max-width: 1120px;
      padding-block: 0.5rem;
      padding-inline: 1.5rem;
      background-color: color-mix(in srgb, var(--color-ink) 92%, transparent);
      -webkit-backdrop-filter: blur(12px) saturate(140%);
      backdrop-filter: blur(12px) saturate(140%);
      border-color: rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      box-shadow: var(--shadow-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav,
    .nav__inner {
      transition: none;
    }
  }
</style>
