---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Gallery from '../../components/Gallery.astro';
import VenueButtons from '../../components/VenueButtons.astro';
import { units } from '../../data/units.js';

export function getStaticPaths() {
  return units.map((unit) => ({
    params: { id: unit.id },
    props: { unit },
  }));
}

const { unit } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const asset = (p) => base + p.replace(/^\//, '');
const fleetHref = `${base}#fleet`;

const specEntries = Object.entries(unit.specs || {});
const hasRequirements = Array.isArray(unit.requirements) && unit.requirements.length > 0;
const hasPricing = unit.pricing && (unit.pricing.sixHour || unit.pricing.eightHour);

// Resolve an optional floor-plan image (line diagram) for this unit.
const fpModules = import.meta.glob('../../assets/units/*/*.{jpg,png}', { eager: true });
let floorplanImg = null;
if (unit.floorplan) {
  for (const [path, mod] of Object.entries(fpModules)) {
    if (path.endsWith(`/${unit.id}/${unit.floorplan}`)) {
      floorplanImg = mod.default;
      break;
    }
  }
}

// Map "<unitId>/<file>" -> imported image, for per-model cards (jet skis).
const unitImageMap = {};
for (const [path, mod] of Object.entries(fpModules)) {
  const m = path.match(/units\/([^/]+)\/([^/]+)$/);
  if (m) unitImageMap[`${m[1]}/${m[2]}`] = mod.default;
}
const models = (unit.models || []).map((mdl) => ({
  ...mdl,
  img: unitImageMap[`${unit.id}/${mdl.image}`] || null,
}));

const title = `${unit.name} | ${unit.yearMakeModel} | Boss Life Rentals`;
const description = `${unit.summary} Book ${unit.name} in Sarasota, kept clean, fueled, and ready by a local family.`;
---

<Base path={`/fleet/${unit.id}`} title={title} description={description}>
  <Nav onDetail={true} />

  <main id="top">
    <!-- Hero -->
    <header class={`detail-hero${unit.heroVideo ? ' detail-hero--video' : ''}`}>
      {
        unit.heroVideo && (
          <div class="detail-hero__media" aria-hidden="true">
            <video
              class="detail-hero__video"
              autoplay
              muted
              loop
              playsinline
              preload="none"
              poster={unit.heroPoster ? asset(unit.heroPoster) : undefined}
              data-detail-video
            >
              <source src={asset(unit.heroVideo)} type="video/mp4" />
            </video>
            <div class="detail-hero__video-scrim" />
          </div>
        )
      }
      <div class="container-x detail-hero__inner reveal">
        <h1 class="t-editorial">{unit.name}</h1>
        <p class="detail-hero__model">{unit.typeLabel} · {unit.yearMakeModel}</p>
        <div class="detail-hero__chips">
          {unit.chips.map((c) => <span class="chip chip--dark">{c}</span>)}
        </div>
      </div>
    </header>

    <div class="container-x detail">
      <!-- Gallery -->
      <section class="detail__gallery reveal" aria-label={`${unit.name} photos`}>
        <Gallery unit={unit} />
      </section>

      <!-- Overview -->
      <div class="detail__cols">
        <div class="detail__main">
          <section class="block reveal" aria-labelledby="overview-h">
            <h2 class="t-h2" id="overview-h">{unit.tagline}</h2>
            <p class="block__body detail__summary">{unit.summary}</p>
          </section>

          {
            models.length > 0 && (
              <section class="block reveal" aria-labelledby="models-h">
                <h2 class="t-h2" id="models-h">Two to choose from</h2>
                <p class="block__body">
                  Same easy ride, your pick of power. The yellow 170 has a little more pull, and the
                  orange 130 is smooth and friendly.
                </p>
                <div class="models">
                  {models.map((m) => (
                    <article class="modelcard">
                      <div class="modelcard__media">
                        {m.img && (
                          <Image
                            src={m.img}
                            alt={`Sea-Doo ${m.name}, ${m.color}.`}
                            widths={[400, 640, 800]}
                            sizes="(min-width: 720px) 40vw, 100vw"
                            loading="lazy"
                          />
                        )}
                      </div>
                      <div class="modelcard__body">
                        <h3 class="modelcard__name">{m.name}</h3>
                        <p class="modelcard__color">{m.color}</p>
                        <div class="modelcard__specs">
                          <span class="modelcard__spec">
                            <span class="modelcard__spec-k">Power</span>
                            <span class="modelcard__spec-v">{m.power}</span>
                          </span>
                          <span class="modelcard__spec">
                            <span class="modelcard__spec-k">Top speed</span>
                            <span class="modelcard__spec-v">{m.topSpeed}</span>
                          </span>
                        </div>
                        <p class="modelcard__blurb">{m.blurb}</p>
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            )
          }

          {
            unit.highlight && (
              <section class="block reveal highlightcard" aria-labelledby="highlight-h">
                <h2 class="t-h2 highlightcard__title" id="highlight-h">{unit.highlight.title}</h2>
                <p class="highlightcard__body">{unit.highlight.body}</p>
                <ul class="highlightcard__list">
                  {unit.highlight.points.map((p) => (
                    <li>
                      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <circle cx="10" cy="10" r="8.25" stroke="currentColor" stroke-width="1.5" />
                        <path d="M6.5 10.2l2.3 2.3 4.7-4.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              </section>
            )
          }

          {
            specEntries.length > 0 && (
              <section class="block reveal" aria-labelledby="specs-h">
                <h2 class="t-h2" id="specs-h">Specs</h2>
                <div class="specs">
                  {specEntries.map(([k, v]) => (
                    <div class="specs__row">
                      <span class="specs__key">{k}</span>
                      <span class="specs__val">{v}</span>
                    </div>
                  ))}
                </div>
              </section>
            )
          }

          {
            unit.features && unit.features.length > 0 && (
              <section class="block reveal" aria-labelledby="features-h">
                <h2 class="t-h2" id="features-h">Features</h2>
                <ul class="feat-list">
                  {unit.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
              </section>
            )
          }

          {
            floorplanImg && (
              <section class="block reveal" aria-labelledby="floorplan-h">
                <h2 class="t-h2" id="floorplan-h">Floor plan</h2>
                <figure class="floorplan">
                  <Image
                    src={floorplanImg}
                    alt={`Floor plan of the ${unit.name}.`}
                    widths={[600, 900, 1235]}
                    sizes="(min-width: 960px) 60vw, 100vw"
                    loading="lazy"
                  />
                </figure>
              </section>
            )
          }

          {
            unit.included && (
              <section class="block reveal" aria-labelledby="included-h">
                <h2 class="t-h2" id="included-h">What is included</h2>
                <p class="block__body">{unit.included}</p>
              </section>
            )
          }

          {
            unit.walkthrough && (
              <section class="block reveal" aria-labelledby="walkthrough-h">
                <h2 class="t-h2" id="walkthrough-h">We meet you in person</h2>
                <p class="block__body">{unit.walkthrough}</p>
              </section>
            )
          }

          {
            hasRequirements && (
              <section class="block reveal" aria-labelledby="req-h">
                <h2 class="t-h2" id="req-h">A few simple things to rent</h2>
                <ul class="req-list">
                  {unit.requirements.map((r) => (
                    <li>
                      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <circle cx="10" cy="10" r="8.25" stroke="currentColor" stroke-width="1.5" />
                        <path d="M6.5 10.2l2.3 2.3 4.7-4.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <span>{r}</span>
                    </li>
                  ))}
                </ul>
              </section>
            )
          }

          {
            unit.operatingArea && (
              <section class="block reveal" aria-labelledby="area-h">
                <h2 class="t-h2" id="area-h">Operating area</h2>
                <p class="block__body">{unit.operatingArea}</p>
              </section>
            )
          }
        </div>

        <!-- Sidebar: pricing + booking -->
        <aside class="detail__aside">
          <div class="booking-card reveal">
            {
              hasPricing && (
                <div class="booking-card__pricing">
                  <p class="booking-card__rates-label">Rental rates</p>
                  <div class="pricing">
                    {unit.pricing.sixHour && (
                      <div class="pricing__cell">
                        <p class="pricing__label">6 hour</p>
                        <p class="pricing__amt">${unit.pricing.sixHour}</p>
                      </div>
                    )}
                    {unit.pricing.eightHour && (
                      <div class="pricing__cell">
                        <p class="pricing__label">8 hour</p>
                        <p class="pricing__amt">${unit.pricing.eightHour}</p>
                      </div>
                    )}
                  </div>
                </div>
              )
            }
            <div class="booking-card__venues">
              <VenueButtons venues={unit.venues} label="Book this one" bookName={unit.name} />
            </div>
            <p class="booking-card__longterm">
              Planning a longer stay? We do long-term rentals on this one. Book direct and tell us your dates.
            </p>
          </div>
        </aside>
      </div>

      <a class="back-link detail__back reveal" href={fleetHref}>
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M12.5 8H3.5M3.5 8L7.5 4M3.5 8L7.5 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Back to the fleet
      </a>
    </div>
  </main>

  <script is:inline>
    // Play the detail hero accent only when motion is allowed and the viewport is
    // wide enough; otherwise the poster frame stands (no cellular autoplay).
    (function () {
      var v = document.querySelector('[data-detail-video]');
      if (!v) return;
      var allowMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      var wideEnough = window.matchMedia('(min-width: 768px)').matches;
      if (allowMotion && wideEnough) {
        v.preload = 'auto';
        var tryPlay = function () {
          v.playbackRate = 0.5; // slow, premium rotation
          var p = v.play();
          if (p && p.catch) p.catch(function () {});
        };
        if (v.readyState >= 2) tryPlay();
        else v.addEventListener('loadeddata', tryPlay, { once: true });
      } else {
        v.removeAttribute('autoplay');
      }
    })();
  </script>

  <Footer />
</Base>

<style>
  .detail {
    padding-top: clamp(2rem, 1.5rem + 2vw, 3rem);
    padding-bottom: clamp(4rem, 3rem + 4vw, 7rem);
  }
  .detail__gallery {
    margin-bottom: clamp(3rem, 2rem + 4vw, 5rem);
  }
  .detail__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 2rem + 3vw, 4rem);
    align-items: start;
  }
  .detail__summary {
    margin-top: 1.25rem;
    font-size: 1.1875rem;
  }
  .detail__main .block:first-child h2 {
    max-width: 22ch;
  }

  .detail__aside {
    position: relative;
  }
  .booking-card {
    background: var(--color-surface);
    border: 1px solid color-mix(in srgb, var(--color-slate) 22%, transparent);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 1.25rem + 1vw, 2rem);
    box-shadow: var(--shadow-md);
  }
  .booking-card__pricing {
    margin-bottom: 1.75rem;
  }
  .booking-card__rates-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-slate);
  }
  .booking-card__pricing .pricing {
    margin-top: 1rem;
    max-width: none;
  }
  .booking-card__pricing .pricing__cell {
    background: var(--color-white);
  }

  /* Off-grid / standout highlight: one navy callout card on the light detail
     page, sun-accented checklist. Renders only when a unit defines `highlight`. */
  .highlightcard {
    background:
      radial-gradient(120% 130% at 100% 0%, #0a3a78 0%, var(--color-ink) 60%);
    color: var(--color-white);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 1.25rem + 1.5vw, 2.5rem);
    box-shadow: var(--shadow-md);
  }
  .highlightcard__title {
    color: var(--color-white);
    max-width: 20ch;
  }
  .highlightcard__body {
    margin-top: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.86);
    max-width: 54ch;
  }
  .highlightcard__list {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .highlightcard__list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 1.0625rem;
    line-height: 1.5;
  }
  .highlightcard__list li svg {
    flex: none;
    width: 1.3rem;
    height: 1.3rem;
    margin-top: 0.15rem;
    color: var(--color-sun);
  }

  /* Optional rotating-boat hero accent. The clip is a boat on black, so we blend
     it into the brand navy with mix-blend screen (black -> navy, the light boat
     shows) and bias it to the right with a navy scrim over the headline side. */
  .detail-hero--video .detail-hero__inner {
    position: relative;
    z-index: 1;
  }
  .detail-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .detail-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 68% center;
    mix-blend-mode: screen;
    opacity: 0.9;
  }
  .detail-hero__video-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      var(--color-ink) 0%,
      rgba(0, 36, 84, 0.72) 34%,
      rgba(0, 36, 84, 0.1) 66%,
      rgba(0, 36, 84, 0) 100%
    );
  }
  @media (prefers-reduced-motion: reduce) {
    .detail-hero__video {
      /* poster frame only, no motion */
    }
  }

  /* Two-model picker (jet skis): a clean white card per ski, the studio profile
     on white reading as a catalog shot, with the per-ski power and top speed. */
  .models {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 0.75rem + 1.5vw, 1.5rem);
  }
  .modelcard {
    background: var(--color-white);
    border: 1px solid color-mix(in srgb, var(--color-slate) 18%, transparent);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .modelcard__media {
    aspect-ratio: 4 / 3;
    background: var(--color-white);
  }
  .modelcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .modelcard__body {
    padding: clamp(1.125rem, 0.9rem + 1vw, 1.5rem);
  }
  .modelcard__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.375rem;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .modelcard__color {
    margin-top: 0.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-azure-ink);
  }
  .modelcard__specs {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .modelcard__spec {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.625rem 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }
  .modelcard__spec-k {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
  }
  .modelcard__spec-v {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.125rem;
    color: var(--color-ink);
  }
  .modelcard__blurb {
    margin-top: 1rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-ink);
  }
  @media (min-width: 720px) {
    .models {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Floor plan: line diagram on white, in a clean card on the light page. */
  .floorplan {
    margin: 1.25rem 0 0;
    background: var(--color-white);
    border: 1px solid color-mix(in srgb, var(--color-slate) 20%, transparent);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 0.75rem + 1.5vw, 1.75rem);
    box-shadow: var(--shadow-sm);
  }
  .floorplan img {
    width: 100%;
    height: auto;
    display: block;
  }

  .detail__back {
    margin-top: clamp(3rem, 2rem + 3vw, 4.5rem);
    font-size: 1.0625rem;
  }

  @media (min-width: 960px) {
    .detail__cols {
      grid-template-columns: 1.55fr 0.95fr;
      gap: clamp(3rem, 2rem + 3vw, 5rem);
    }
    .booking-card {
      position: sticky;
      top: 6rem;
    }
  }
</style>
