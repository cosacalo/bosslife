  .fc-loc__name { font-family: var(--font-display); font-weight: 700; font-size: 0.9375rem; line-height: 1.2; color: var(--color-slate); }
  .fc-loc__sub { font-size: 0.6875rem; font-weight: 500; color: color-mix(in srgb, var(--color-slate) 88%, transparent); }
