  .fc-tide-svg { width: 100%; height: 230px; display: block; }
  .fc-tide-events { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 10px; border-top: 1px solid color-mix(in srgb, var(--color-slate) 18%, transparent); }
  .fc-tev { padding: 11px 6px 2px; text-align: center; border-right: 1px solid color-mix(in srgb, var(--color-slate) 18%, transparent); }
