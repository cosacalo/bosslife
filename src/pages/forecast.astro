  .fc-loc:hover .fc-loc__name { color: var(--color-azure-ink); }
  .fc-loc:focus-visible { outline: none; box-shadow: var(--focus-ring); border-color: var(--color-azure); }
  .fc-loc[aria-pressed="true"] {
    background: var(--color-white);
