  .fc-title { font-family: var(--font-display); font-weight: 800; font-size: clamp(34px, 4vw, 50px); line-height: 1.1; letter-spacing: -0.025em; margin: 8px 0 7px; color: var(--color-ink); }
  .fc-subtitle { font-size: 16px; color: var(--color-slate); font-weight: 500; }
  .fc-subtitle b { color: var(--color-ink); font-weight: 600; }
  .fc-head-right { display: flex; flex-direction: column; align-items: flex-end; gap: 14px; flex-shrink: 0; }
  .fc-datebox { background: radial-gradient(130% 130% at 20% 10%, #0a3a78, #002454); color: var(--color-white); text-align: center; padding: 14px 22px 16px; border-radius: 18px; min-width: 132px; box-shadow: var(--shadow-md); }
  .fc-dow { font-weight: 600; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.75; }
  .fc-dnum { font-family: var(--font-display); font-weight: 800; font-size: 46px; line-height: 0.95; margin-top: 2px; }
  .fc-dmo { font-weight: 500; font-size: 13px; letter-spacing: 0.06em; margin-top: 3px; opacity: 0.85; }
  .fc-badge { display: inline-flex; align-items: center; gap: 9px; background: var(--color-sun); color: var(--color-ink); font-family: var(--font-display); font-weight: 800; font-size: 18px; padding: 11px 20px; border-radius: 999px; white-space: nowrap; box-shadow: 0 6px 18px rgba(252, 216, 12, 0.35); }
  .fc-badge--watch { background: #ffe88a; }
  .fc-badge--caution { background: var(--color-white); color: var(--color-ink); border: 2px solid #e8a13c; box-shadow: 0 6px 18px rgba(232, 161, 60, 0.25); }
  .fc-badge svg { flex-shrink: 0; }

  .fc-window { margin-top: 24px; display: flex; align-items: center; gap: 26px; background: color-mix(in srgb, var(--color-sun) 16%, var(--color-white)); border: 1px solid color-mix(in srgb, var(--color-sun) 55%, transparent); border-radius: 18px; padding: 18px 24px; }
  .fc-wleft { flex-shrink: 0; padding-right: 26px; border-right: 1px solid color-mix(in srgb, var(--color-ink) 14%, transparent); }
  .fc-wlabel { font-weight: 600; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-slate); }
  .fc-wtime { font-family: var(--font-display); font-weight: 800; font-size: 28px; line-height: 1.05; color: var(--color-ink); white-space: nowrap; margin-top: 3px; }
  .fc-wnote { flex: 1; font-size: 15.5px; line-height: 1.5; color: var(--color-ink); }
