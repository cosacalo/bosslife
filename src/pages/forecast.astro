---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { LOCATIONS } from '../lib/boating-forecast.js';

// Base-path-aware asset URL (matches the rest of the site).
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const logo = base + 'forecast-logo.png';
const homeHref = base;
---

<Base
  path="/forecast"
  title="Boating Forecast | Boss Life Rentals"
  description="A live Sarasota boating forecast for your rental day: wind, seas, rain, UV, tides, and sun, pulled straight from the official NOAA models."
  ogImage="og-forecast.jpg"
  ogAlt="Sarasota boating forecast: live wind, seas, tide, and sun for your day on the water."
>
  {/* Live forecast tool, linked from the main nav (as a real page, with an arrow
      marker to distinguish it from the in-page anchor jumps). All data is fetched
      client-side from Open-Meteo (NOAA models) and NOAA CO-OPS, both CORS-open, so
      this works on the static GitHub Pages build with no backend. */}
  <header class="fc-topnav">
    <div class="container-x fc-topnav__inner">
      <a href={homeHref} aria-label="Boss Life Rentals, home">
        <img src={logo} alt="Boss Life Rentals" width="150" height="75" />
      </a>
      <a href={homeHref} class="fc-topnav__back">Back to home</a>
    </div>
  </header>

  <main id="forecast-app" class="fc-main">
    <div class="container-x">
      <p class="t-eyebrow fc-eyebrow">Boating Forecast</p>
      <h1 class="t-h1">Check your day on the water</h1>
      <p class="fc-lede">
        Pick your rental day and window. We pull the live numbers straight from the
        official NOAA models and the NOAA tide station, and build your card. Real
        values only. Nothing guessed.
      </p>

      {/* ---- Controls ---- */}
      <form class="fc-controls" id="fc-form" autocomplete="off">
        <div class="fc-field">
          <label for="fc-date">Rental day</label>
          <input type="date" id="fc-date" name="date" required />
        </div>
        <div class="fc-field">
          <label for="fc-start">Start</label>
          <input type="time" id="fc-start" name="start" value="09:00" step="900" required />
        </div>
        <div class="fc-field">
          <label for="fc-end">End</label>
          <input type="time" id="fc-end" name="end" value="17:00" step="900" required />
        </div>
        <button type="submit" class="btn btn-primary fc-go">Update card</button>
        <button type="button" class="btn btn-secondary fc-copy" id="fc-copy">Copy link</button>
      </form>

      {/* ---- Status / errors ---- */}
      <div class="fc-status" id="fc-status" role="status" aria-live="polite"></div>

      {/* ---- Launch location tabs (folder tabs on the card) ---- */}
      {/* Weather and tides shift between our ramps, so the renter picks their
          pickup location and the card below re-pulls for it. Sits right on the
          card, least disturbance to the rest of the page. Centennial is the
          included home base; the others are add-on pickups. */}
      <div class="fc-locs" role="group" aria-label="Forecast location">
        <div class="fc-locs__set" id="fc-locs">
          {LOCATIONS.map((loc, i) => (
            <button
              type="button"
              class="fc-loc"
              data-loc={loc.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="fc-loc__name">{loc.name}</span>
              <span class="fc-loc__sub">{loc.sub}</span>
            </button>
          ))}
        </div>
      </div>

      {/* ---- The card (rendered by JS) ---- */}
      <div class="fc-cardwrap">
        <div class="fc-card" id="fc-card" aria-live="polite" data-logo={logo}>
          <div class="fc-inner" id="fc-inner"></div>
        </div>
      </div>

      {/* ---- Sources / honesty footnote ---- */}
      <p class="fc-sources" id="fc-sources">
        Wind, rain, seas, UV, and sun come from the
        <a href="https://open-meteo.com/" target="_blank" rel="noopener">Open-Meteo</a>
        run of the NOAA forecast models. Tides come from
        <a id="fc-tide-source" href="https://tidesandcurrents.noaa.gov/stationhome.html?id=8726083" target="_blank" rel="noopener">NOAA station 8726083 (Sarasota Bay)</a>.
        Forecast only. Always check conditions yourself before you leave the ramp.
      </p>
    </div>
  </main>

  <Footer />
</Base>

<script>
import { fetchAll, deriveConditions, etToday, shiftYmd, timeToDec, pad2, locationById, DEFAULT_LOCATION } from '../lib/boating-forecast.js';
/* ============================================================================
   Boss Life — live boating forecast page (Option A: fully automatic).
   Data + derivation come from ../lib/boating-forecast.js (shared with the
   homepage "Today on the bay" band). This file owns only the card rendering:
   the SVG charts, icons, DOM, and the date/window controls.
   ============================================================================ */
(function () {
  'use strict';

  var LOGO_URL = document.getElementById('fc-card').getAttribute('data-logo');

  /* ---- brand palette for the SVGs ---- */
  var INK = '#002454', AZURE = '#0c78e4', AZURE_INK = '#0a63c4', SLATE = '#5b708a',
      SUN = '#fcd80c', WHITE = '#ffffff', AZURE_LT = '#9cc6f2';
  var FONT = "'Hanken Grotesk Variable','Hanken Grotesk',sans-serif",
      DISPLAY = "'Bricolage Grotesque Variable','Bricolage Grotesque',sans-serif";

  /* trip window in decimal hours, set per render */
  var WIN_START = 9.0, WIN_END = 17.0;

  /* -------------------------------------------------------------- SVG: tide */
  function buildTideSVG(f) {
    var W = 1000, H = 230, padT = 34, padB = 40, padL = 10, padR = 10;
    var plotW = W - padL - padR, plotH = H - padT - padB;
    var evs = f.tides.map(function (p) { return { t: p.t, v: p.ft }; });
    if (!evs.length) {
      return '<svg class="fc-tide-svg" viewBox="0 0 ' + W + ' ' + H + '"><text x="' + (W / 2) +
        '" y="' + (H / 2) + '" text-anchor="middle" font-family="' + FONT + '" font-size="15" fill="' + SLATE +
        '">Tide data unavailable for this day.</text></svg>';
    }
    var ex = [];
    if (f._tideAnchors && f._tideAnchors.prev) ex.push(f._tideAnchors.prev);
    else ex.push({ t: evs[0].t - 6.2, v: evs[0].v });
    evs.forEach(function (e) { ex.push(e); });
    if (f._tideAnchors && f._tideAnchors.next) ex.push(f._tideAnchors.next);
    else ex.push({ t: evs[evs.length - 1].t + 6.2, v: evs[evs.length - 1].v });

    var vals = ex.map(function (e) { return e.v; });
    var minV = Math.min.apply(null, vals) - 0.5, maxV = Math.max.apply(null, vals) + 0.4;
    if (maxV - minV < 1) maxV = minV + 1;
    var x = function (t) { return padL + (t / 24) * plotW; };
    var y = function (v) { return padT + (1 - (v - minV) / (maxV - minV)) * plotH; };
    function val(t) {
      for (var i = 0; i < ex.length - 1; i++) {
        if (t >= ex[i].t && t <= ex[i + 1].t) {
          var fr = (1 - Math.cos(Math.PI * (t - ex[i].t) / (ex[i + 1].t - ex[i].t))) / 2;
          return ex[i].v + (ex[i + 1].v - ex[i].v) * fr;
        }
      }
      return t < ex[0].t ? ex[0].v : ex[ex.length - 1].v;
    }
    var pts = [];
    for (var t = 0; t <= 24.001; t += 0.2) pts.push([x(t), y(val(t))]);
    var line = pts.map(function (p, i) { return (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1); }).join(' ');
    var area = line + ' L ' + x(24).toFixed(1) + ' ' + (padT + plotH).toFixed(1) + ' L ' + padL.toFixed(1) + ' ' + (padT + plotH).toFixed(1) + ' Z';
    var baseY = padT + plotH;
    var wx1 = x(WIN_START), wx2 = x(WIN_END);
    var ticks = [0, 6, 12, 18, 24], tickLabels = { 0: '12A', 6: '6A', 12: '12P', 18: '6P', 24: '12A' };

    var markers = f.tides.map(function (p) {
      var px = x(p.t), py = y(p.ft), high = p.type === 'h', col = high ? AZURE : SLATE;
      var lblY = high ? py - 14 : py + 24;
      return '<circle cx="' + px.toFixed(1) + '" cy="' + py.toFixed(1) + '" r="6" fill="' + WHITE + '" stroke="' + col + '" stroke-width="2.5"/>' +
        '<circle cx="' + px.toFixed(1) + '" cy="' + py.toFixed(1) + '" r="2.2" fill="' + col + '"/>' +
        '<text x="' + px.toFixed(1) + '" y="' + lblY.toFixed(1) + '" text-anchor="middle" font-family="' + FONT + '" font-size="13" font-weight="700" fill="' + INK + '">' + p.ft.toFixed(2) + ' ft</text>';
    }).join('');

    function sunTick(t, label) {
      var px = x(t);
      return '<line x1="' + px.toFixed(1) + '" y1="' + baseY.toFixed(1) + '" x2="' + px.toFixed(1) + '" y2="' + (baseY + 6).toFixed(1) + '" stroke="' + SLATE + '" stroke-width="1"/>' +
        '<text x="' + px.toFixed(1) + '" y="' + (baseY + 22).toFixed(1) + '" text-anchor="middle" font-family="' + FONT + '" font-size="11.5" font-weight="500" fill="' + SLATE + '">' + label + '</text>';
    }

    return '<svg class="fc-tide-svg" viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="none">' +
      '<defs><linearGradient id="fcSeaFill" x1="0" y1="0" x2="0" y2="1">' +
      '<stop offset="0" stop-color="' + AZURE + '" stop-opacity="0.32"/>' +
      '<stop offset="1" stop-color="' + AZURE + '" stop-opacity="0.05"/></linearGradient></defs>' +
      '<rect x="' + wx1.toFixed(1) + '" y="' + padT.toFixed(1) + '" width="' + (wx2 - wx1).toFixed(1) + '" height="' + plotH.toFixed(1) + '" fill="' + SUN + '" opacity="0.22" rx="4"/>' +
      '<line x1="' + wx1.toFixed(1) + '" y1="' + padT + '" x2="' + wx1.toFixed(1) + '" y2="' + baseY + '" stroke="' + SUN + '" stroke-width="2" stroke-dasharray="3 3"/>' +
      '<line x1="' + wx2.toFixed(1) + '" y1="' + padT + '" x2="' + wx2.toFixed(1) + '" y2="' + baseY + '" stroke="' + SUN + '" stroke-width="2" stroke-dasharray="3 3"/>' +
      '<text x="' + ((wx1 + wx2) / 2).toFixed(1) + '" y="' + (padT - 13).toFixed(1) + '" text-anchor="middle" font-family="' + DISPLAY + '" font-size="11.5" font-weight="800" letter-spacing="1.2" fill="' + AZURE_INK + '">YOUR TRIP</text>' +
      ticks.map(function (t) { return '<line x1="' + x(t).toFixed(1) + '" y1="' + padT + '" x2="' + x(t).toFixed(1) + '" y2="' + baseY + '" stroke="' + INK + '" stroke-opacity="0.06" stroke-width="1"/>'; }).join('') +
      '<path d="' + area + '" fill="url(#fcSeaFill)"/>' +
      '<path d="' + line + '" fill="none" stroke="' + AZURE + '" stroke-width="3" stroke-linejoin="round"/>' +
      '<line x1="' + padL + '" y1="' + baseY + '" x2="' + (W - padR) + '" y2="' + baseY + '" stroke="' + INK + '" stroke-opacity="0.5" stroke-width="1.2"/>' +
      ticks.map(function (t) { return sunTick(t, tickLabels[t]); }).join('') + markers + '</svg>';
  }

  /* -------------------------------------------------------------- SVG: rain */
  function buildRainSVG(f) {
    var W = 1000, H = 150, padT = 16, padB = 24, padL = 10, padR = 10;
    var plotW = W - padL - padR, plotH = H - padT - padB;
    var hourly = f.rain.hourly;
    var x = function (t) { return padL + (t / 24) * plotW; };
    var base = padT + plotH, yTop = padT, barW = (plotW / 24) * 0.62;
    var wx1 = x(WIN_START), wx2 = x(WIN_END), y50 = base - 0.5 * plotH;
    var ticks = [0, 6, 12, 18, 24], lbl = { 0: '12A', 6: '6A', 12: '12P', 18: '6P', 24: '12A' };

    var barLabels = '';
    var bars = hourly.map(function (p, h) {
      var cx = x(h + 0.5), bh = Math.max(2, (p / 100) * plotH);
      var inWin = (h + 0.5) >= WIN_START && (h + 0.5) <= WIN_END, col = inWin ? AZURE : AZURE_LT;
      if (inWin && p >= 5) {
        var ly = Math.min(base - bh - 7, base - 14);
        barLabels += '<text x="' + cx.toFixed(1) + '" y="' + ly.toFixed(1) + '" text-anchor="middle" font-family="' + FONT + '" font-size="13" font-weight="700" fill="' + AZURE_INK + '">' + p + '%</text>';
      }
      return '<rect x="' + (cx - barW / 2).toFixed(1) + '" y="' + (base - bh).toFixed(1) + '" width="' + barW.toFixed(1) + '" height="' + bh.toFixed(1) + '" rx="3" fill="' + col + '"/>';
    }).join('');

    return '<svg class="fc-rain-svg" viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="none">' +
      '<rect x="' + wx1.toFixed(1) + '" y="' + yTop + '" width="' + (wx2 - wx1).toFixed(1) + '" height="' + plotH.toFixed(1) + '" fill="' + SUN + '" opacity="0.22" rx="4"/>' +
      '<line x1="' + wx1.toFixed(1) + '" y1="' + yTop + '" x2="' + wx1.toFixed(1) + '" y2="' + base + '" stroke="' + SUN + '" stroke-width="2" stroke-dasharray="3 3"/>' +
      '<line x1="' + wx2.toFixed(1) + '" y1="' + yTop + '" x2="' + wx2.toFixed(1) + '" y2="' + base + '" stroke="' + SUN + '" stroke-width="2" stroke-dasharray="3 3"/>' +
      '<line x1="' + padL + '" y1="' + y50.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y50.toFixed(1) + '" stroke="' + INK + '" stroke-opacity="0.1" stroke-dasharray="3 4"/>' +
      '<text x="' + (padL + 2) + '" y="' + (yTop + 9).toFixed(1) + '" font-family="' + FONT + '" font-size="10.5" font-weight="500" fill="' + SLATE + '">100%</text>' +
      '<text x="' + (padL + 2) + '" y="' + (y50 - 3).toFixed(1) + '" font-family="' + FONT + '" font-size="10.5" font-weight="500" fill="' + SLATE + '">50%</text>' +
      bars + barLabels +
      '<line x1="' + padL + '" y1="' + base + '" x2="' + (W - padR) + '" y2="' + base + '" stroke="' + INK + '" stroke-opacity="0.5" stroke-width="1.2"/>' +
      ticks.map(function (t) { return '<line x1="' + x(t).toFixed(1) + '" y1="' + base + '" x2="' + x(t).toFixed(1) + '" y2="' + (base + 5) + '" stroke="' + SLATE + '" stroke-width="1"/><text x="' + x(t).toFixed(1) + '" y="' + (base + 18).toFixed(1) + '" text-anchor="middle" font-family="' + FONT + '" font-size="11.5" font-weight="500" fill="' + SLATE + '">' + lbl[t] + '</text>'; }).join('') +
      '</svg>';
  }

  /* ------------------------------------------------------------------ icons */
  function windIcon() { return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="' + INK + '" stroke-width="1.8" stroke-linecap="round"><path d="M3 9h11.5a2.5 2.5 0 1 0-2.5-2.5"/><path d="M3 14h15a2.5 2.5 0 1 1-2.5 2.5"/></svg>'; }
  function seaIcon() { return '<svg width="24" height="22" viewBox="0 0 26 22" fill="none" stroke="' + INK + '" stroke-width="1.8" stroke-linecap="round"><path d="M2 7q3-3.2 6 0t6 0 6 0"/><path d="M2 13q3-3.2 6 0t6 0 6 0"/><path d="M2 19q3-3.2 6 0t6 0 6 0"/></svg>'; }
  function uvIcon() {
    var spokes = [0, 45, 90, 135, 180, 225, 270, 315].map(function (a) {
      var r = a * Math.PI / 180, x1 = 12 + Math.cos(r) * 7, y1 = 12 + Math.sin(r) * 7, x2 = 12 + Math.cos(r) * 9.2, y2 = 12 + Math.sin(r) * 9.2;
      return '<line x1="' + x1.toFixed(1) + '" y1="' + y1.toFixed(1) + '" x2="' + x2.toFixed(1) + '" y2="' + y2.toFixed(1) + '"/>';
    }).join('');
    return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="' + INK + '" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"/>' + spokes + '</svg>';
  }
  function cloudRainIcon() { return '<svg width="26" height="23" viewBox="0 0 28 26" fill="none" stroke="' + AZURE_INK + '" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 16a4.5 4.5 0 0 1-.3-9 6 6 0 0 1 11.3 1.2A4 4 0 0 1 20 16"/><line x1="9" y1="19" x2="8" y2="22"/><line x1="14" y1="19.5" x2="13" y2="22.5"/><line x1="19" y1="19" x2="18" y2="22"/></svg>'; }
  function tideIcon() { return '<svg width="24" height="22" viewBox="0 0 26 22" fill="none" stroke="' + AZURE_INK + '" stroke-width="1.8" stroke-linecap="round"><path d="M2 15q3.5-7 6.5 0t6.5 0 6.5 0"/><line x1="2" y1="19.5" x2="23" y2="19.5"/></svg>'; }
  function checkIcon() { return '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="' + INK + '" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5l3.5 3.5L15 5"/></svg>'; }
  function alertIcon() { return '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="' + INK + '" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2.5 16.5 15.5H1.5z"/><line x1="9" y1="7.5" x2="9" y2="11"/><circle cx="9" cy="13.4" r="0.2"/></svg>'; }
  function sunriseIcon(c) { return '<svg width="34" height="34" viewBox="0 0 34 34" fill="none" stroke="' + c + '" stroke-width="1.9" stroke-linecap="round"><line x1="5" y1="25" x2="29" y2="25"/><path d="M11 25a6 6 0 0 1 12 0"/><line x1="17" y1="8" x2="17" y2="13"/><line x1="8.5" y1="12" x2="11.5" y2="14.5"/><line x1="25.5" y1="12" x2="22.5" y2="14.5"/><path d="M13 20l4-4 4 4"/></svg>'; }
  function sunsetIcon(c) { return '<svg width="34" height="34" viewBox="0 0 34 34" fill="none" stroke="' + c + '" stroke-width="1.9" stroke-linecap="round"><line x1="5" y1="25" x2="29" y2="25"/><path d="M11 25a6 6 0 0 1 12 0"/><line x1="17" y1="13" x2="17" y2="8"/><line x1="8.5" y1="12" x2="11.5" y2="14.5"/><line x1="25.5" y1="12" x2="22.5" y2="14.5"/><path d="M13 16l4 4 4-4"/></svg>'; }

  /* ----------------------------------------------------------------- render */
  function render(f) {
    var tideEvents = f.tides.map(function (p) {
      var high = p.type === 'h';
      return '<div class="fc-tev"><div class="fc-tk ' + (high ? 'high' : 'low') + '">' + (high ? 'High' : 'Low') +
        ' Tide</div><div class="fc-tf">' + p.ft.toFixed(2) + '<span style="font-size:14px;color:' + SLATE + ';font-weight:600"> ft</span></div>' +
        '<div class="fc-tt">' + p.time + '</div></div>';
    }).join('') || '<div class="fc-tev" style="grid-column:1 / -1"><div class="fc-tt">No tide predictions for this day.</div></div>';

    var stampIcon = f.verdict.level === 'good' ? checkIcon() : alertIcon();
    var badgeClass = 'fc-badge fc-badge--' + f.verdict.level;

    document.getElementById('fc-inner').innerHTML =
      '<div class="fc-head">' +
        '<div class="fc-head-left">' +
          '<img class="fc-logo" src="' + LOGO_URL + '" alt="Boss Life Rentals" />' +
          '<div class="fc-eyebrow2">Boating Forecast</div>' +
          '<div class="fc-title">' + f.date.dow + "'s Water</div>" +
          '<div class="fc-subtitle">' + f.area + ' &nbsp;&middot;&nbsp; Tides at <b>' + f.station + '</b></div>' +
        '</div>' +
        '<div class="fc-head-right">' +
          '<div class="fc-datebox"><div class="fc-dow">' + f.date.dow + '</div><div class="fc-dnum">' + f.date.num + '</div><div class="fc-dmo">' + f.date.mo + ' ' + f.date.year + '</div></div>' +
          '<div class="' + badgeClass + '">' + stampIcon + ' ' + f.verdict.stamp + '</div>' +
        '</div>' +
      '</div>' +
      '<div class="fc-window">' +
        '<div class="fc-wleft"><div class="fc-wlabel">Your rental window</div><div class="fc-wtime">' + f.window + '</div></div>' +
        '<div class="fc-wnote">' + f.verdict.note + '</div>' +
      '</div>' +
      '<div class="fc-tiles">' +
        '<div class="fc-tile"><div class="fc-ic">' + windIcon() + '</div><div class="fc-tbody"><div class="fc-tlabel">Wind</div><div class="fc-tval">' + f.wind.value + '<span class="fc-u"> ' + f.wind.unit + ' ' + f.wind.dir + '</span></div><div class="fc-tsub">' + f.wind.note + '</div></div></div>' +
        '<div class="fc-tile"><div class="fc-ic">' + seaIcon() + '</div><div class="fc-tbody"><div class="fc-tlabel">Seas</div><div class="fc-tval">' + f.seas.value + '<span class="fc-u"> ' + f.seas.unit + '</span>' + (f.seas.period ? '<span class="fc-period">' + f.seas.period + ' <em>' + f.seas.periodTag + '</em></span>' : '') + '</div><div class="fc-tsub">' + f.seas.note + '</div></div></div>' +
        '<div class="fc-tile"><div class="fc-ic">' + uvIcon() + '</div><div class="fc-tbody"><div class="fc-tlabel">UV index</div><div class="fc-tval">' + f.uv.value + '<span class="fc-u"> ' + f.uv.unit + '</span></div><div class="fc-tsub">' + f.uv.note + '</div></div></div>' +
      '</div>' +
      '<div class="fc-panel"><div class="fc-panel-head"><div class="fc-panel-title">' + cloudRainIcon() + '<span>Rain chance by hour</span></div><div class="fc-panel-tag">' + f.rain.tag + '</div></div>' + buildRainSVG(f) + '<div class="fc-rs-note">' + f.rain.note + '</div></div>' +
      '<div class="fc-panel"><div class="fc-panel-head"><div class="fc-panel-title">' + tideIcon() + '<span>Tide forecast</span></div><div class="fc-panel-tag">High and low tide times</div></div>' + buildTideSVG(f) + '<div class="fc-tide-events">' + tideEvents + '</div></div>' +
      '<div class="fc-sun"><div class="fc-sblk"><div class="fc-sic">' + sunriseIcon(SUN) + '</div><div><div class="fc-slabel">Sunrise</div><div class="fc-sval">' + f.sun.rise + '</div></div></div>' +
        '<div class="fc-sblk"><div class="fc-sic">' + sunsetIcon(SUN) + '</div><div><div class="fc-slabel">Sunset</div><div class="fc-sval">' + f.sun.set + '</div></div></div></div>' +
      '<div class="fc-foot"><div class="fc-fl"><span>Updated</span> &nbsp;<b>' + f.updated + '</b> &nbsp;&middot;&nbsp; Forecast only. Always check conditions before departure.</div><div class="fc-brand">Boss Life Rentals</div></div>';
  }

  /* ------------------------------------------------------------------- glue */
  var statusEl = document.getElementById('fc-status');
  var cardEl = document.getElementById('fc-card');
  var dateEl = document.getElementById('fc-date');
  var startEl = document.getElementById('fc-start');
  var endEl = document.getElementById('fc-end');
  var formEl = document.getElementById('fc-form');
  var locSetEl = document.getElementById('fc-locs');
  var tideSourceEl = document.getElementById('fc-tide-source');

  /* selected launch location (defaults to the included home base) */
  var currentLoc = DEFAULT_LOCATION;

  function setStatus(html, cls) {
    statusEl.className = 'fc-status' + (cls ? ' fc-status--' + cls : '');
    statusEl.innerHTML = html;
  }

  // Reflect the current location into the tab pressed-states and the sources
  // footnote (which station the tides came from), so both stay honest.
  function reflectLocation() {
    var btns = locSetEl.querySelectorAll('.fc-loc');
    for (var i = 0; i < btns.length; i++) {
      btns[i].setAttribute('aria-pressed', btns[i].getAttribute('data-loc') === currentLoc.id ? 'true' : 'false');
    }
    if (tideSourceEl) {
      tideSourceEl.href = 'https://tidesandcurrents.noaa.gov/stationhome.html?id=' + currentLoc.station;
      tideSourceEl.textContent = 'NOAA station ' + currentLoc.station + ' (' + currentLoc.stationLabel.replace(/,\s*NOAA #\d+$/, '') + ')';
    }
  }

  /* ---- shareable-link params (?date=YYYY-MM-DD&start=9:30am&end=3:30pm) ---- */
  // Accepts "09:30", "9:30", "9:30am", "3:30 PM", or bare hour "9" / "9pm".
  // Returns "HH:MM" (24h) for the time input, or null if unparseable.
  function parseTimeParam(v) {
    if (!v) return null;
    var m = String(v).trim().match(/^(\d{1,2})(?::(\d{2}))?\s*([ap]m?)?$/i);
    if (!m) return null;
    var h = +m[1], min = m[2] ? +m[2] : 0, ap = m[3] ? m[3][0].toLowerCase() : '';
    if (ap === 'p' && h < 12) h += 12;
    if (ap === 'a' && h === 12) h = 0;
    if (h > 23 || min > 59) return null;
    return pad2(h) + ':' + pad2(min);
  }
  function parseDateParam(v) {
    if (!v) return null;
    var m = String(v).trim().match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!m) return null;
    var mo = +m[2], da = +m[3];
    if (mo < 1 || mo > 12 || da < 1 || da > 31) return null;
    return m[0];
  }
  // Mirror the current selection into the address bar so the link is always
  // copyable, and feeds Copy link.
  function shareUrl() {
    var qs = 'date=' + encodeURIComponent(dateEl.value) +
      '&start=' + encodeURIComponent(startEl.value) +
      '&end=' + encodeURIComponent(endEl.value) +
      '&loc=' + encodeURIComponent(currentLoc.id);
    return location.origin + location.pathname + '?' + qs;
  }
  function syncUrl() {
    try { history.replaceState(null, '', shareUrl()); } catch (e) { /* ignore */ }
  }

  function load() {
    var date = dateEl.value;
    if (!date) { setStatus('Pick a rental day to see the forecast.', 'info'); return; }
    var s = timeToDec(startEl.value || '09:00'), e = timeToDec(endEl.value || '17:00');
    if (e <= s) { setStatus('Your end time needs to be after your start time.', 'warn'); return; }
    WIN_START = s; WIN_END = e;
    syncUrl(); // keep the address bar shareable

    setStatus('Pulling the live numbers for ' + date + '...', 'info');
    cardEl.classList.add('is-loading');

    fetchAll(date, currentLoc)
      .then(function (raw) {
        var errors = raw.errors;
        var f;
        try { f = deriveConditions(date, raw.fc, raw.mar, raw.tide, errors, WIN_START, WIN_END, currentLoc); }
        catch (err) {
          cardEl.classList.remove('is-loading');
          cardEl.classList.add('is-empty');
          setStatus('Could not build a card. ' + err.message, 'warn');
          return;
        }
        render(f);
        cardEl.classList.remove('is-loading', 'is-empty');

        // Public page: stay quiet on success (the card footer carries the
        // "Updated" timestamp). Only speak up if a source was unavailable.
        if (errors.length) {
          setStatus('<span class="fc-status-warn">Some data was unavailable: ' + errors.join('; ') + '. Those fields are left off, not guessed.</span>', 'warn');
        } else {
          setStatus('', 'ok');
        }
      });
  }

  // Copy link: hands Carlos a ready-to-send URL for the current selection.
  var copyEl = document.getElementById('fc-copy');
  copyEl.addEventListener('click', function () {
    var url = shareUrl();
    var done = function () { copyEl.textContent = 'Copied!'; setTimeout(function () { copyEl.textContent = 'Copy link'; }, 1800); };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(done, function () { window.prompt('Copy this link:', url); });
    } else { window.prompt('Copy this link:', url); }
  });

  // init: defaults, then override from any ?date/?start/?end in the link
  dateEl.min = shiftYmd(etToday(), -1);
  dateEl.max = shiftYmd(etToday(), 15); // Open-Meteo model horizon
  dateEl.value = etToday();

  var params = new URLSearchParams(location.search);
  var qDate = parseDateParam(params.get('date'));
  var qStart = parseTimeParam(params.get('start'));
  var qEnd = parseTimeParam(params.get('end'));
  var qLoc = params.get('loc');
  if (qDate) {
    if (qDate < dateEl.min) dateEl.min = qDate;   // allow a shared link outside the default range
    if (qDate > dateEl.max) dateEl.max = qDate;
    dateEl.value = qDate;
  }
  if (qStart) startEl.value = qStart;
  if (qEnd) endEl.value = qEnd;
  if (qLoc) currentLoc = locationById(qLoc);   // locationById falls back to the home base
  reflectLocation();

  // Pick a launch location: swap the location, keep the day/window, re-pull.
  locSetEl.addEventListener('click', function (ev) {
    var btn = ev.target.closest('.fc-loc');
    if (!btn) return;
    var loc = locationById(btn.getAttribute('data-loc'));
    if (loc.id === currentLoc.id) return;
    currentLoc = loc;
    reflectLocation();
    syncUrl();
    load();
  });

  formEl.addEventListener('submit', function (ev) { ev.preventDefault(); load(); });
  [dateEl, startEl, endEl].forEach(function (el) { el.addEventListener('change', load); });
  load();
})();
</script>

<style is:global>
  /* ===== Forecast page chrome ===== */
  #forecast-app { background-color: var(--color-surface); padding-bottom: clamp(3rem, 2rem + 4vw, 5rem); }
