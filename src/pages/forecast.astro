  .fc-tf { font-family: var(--font-display); font-weight: 800; font-size: 26px; line-height: 1; margin: 4px 0 2px; color: var(--color-ink); }
  .fc-tt { font-size: 12.5px; color: var(--color-slate); font-weight: 500; }

  .fc-sun { margin-top: 16px; display: flex; border-radius: 18px; overflow: hidden; background: radial-gradient(130% 130% at 20% 10%, #0a3a78, #002454); color: var(--color-white); box-shadow: var(--shadow-md); }
  .fc-sblk { flex: 1; display: flex; align-items: center; gap: 14px; padding: 16px 24px; }
  .fc-sblk + .fc-sblk { border-left: 1px solid rgba(255, 255, 255, 0.18); }
  .fc-sic { width: 34px; height: 34px; flex-shrink: 0; }
  .fc-slabel { font-weight: 600; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; }
  .fc-sval { font-family: var(--font-display); font-weight: 800; font-size: 28px; line-height: 1; margin-top: 2px; white-space: nowrap; }

  .fc-foot { margin-top: 18px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; }
  .fc-fl { font-size: 12.5px; color: var(--color-slate); font-weight: 500; }
  .fc-fl span { text-transform: uppercase; letter-spacing: 0.1em; font-size: 10.5px; font-weight: 600; opacity: 0.85; }
  .fc-fl b { color: var(--color-ink); font-weight: 700; }
  .fc-brand { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--color-azure-ink); }

  /* Phone: stack the header + window, keep the card readable */
  @media (max-width: 720px) {
    .fc-head { flex-direction: column; gap: 16px; }
    .fc-head-right { align-items: flex-start; flex-direction: row; gap: 12px; flex-wrap: wrap; }
    .fc-window { flex-direction: column; align-items: flex-start; gap: 12px; }
    .fc-wleft { border-right: none; padding-right: 0; }
    .fc-tiles { grid-template-columns: 1fr; }
  }
</style>
