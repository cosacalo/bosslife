  .fc-tile { background: var(--color-white); border: 1px solid color-mix(in srgb, var(--color-slate) 18%, transparent); border-radius: 18px; padding: 18px; display: flex; gap: 14px; align-items: flex-start; box-shadow: 0 1px 2px rgba(0, 36, 84, 0.05); }
  .fc-ic { flex-shrink: 0; width: 48px; height: 48px; display: grid; place-items: center; border-radius: 50%; background: color-mix(in srgb, var(--color-azure) 12%, var(--color-white)); }
  .fc-tbody { flex: 1; min-width: 0; }
  .fc-tlabel { font-weight: 600; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-slate); }
  .fc-tval { font-family: var(--font-display); font-weight: 800; font-size: 36px; line-height: 1; margin: 5px 0; color: var(--color-ink); white-space: nowrap; letter-spacing: -0.02em; }
